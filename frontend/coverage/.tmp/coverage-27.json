ort React from 'react';\nimport { useNavigate } from 'react-router-dom';\nimport EllipsisCell from '../../components/common/EllipsisCell';\n\nexport default function useSellerColumns() {\n  const navigate = useNavigate();\n\n  return [\n    {\n      name: 'Actions',\n      cell: row => (\n        <button className=\"btn btn-sm\" onClick={() => navigate(`/sellers/${row.id}`)}>\n          ✏️\n        </button>\n      ),\n      ignoreRowClick: true,\n      width: '50px',\n    },\n    { \n      name: 'Identifiant', \n      selector: row => row.legal_identifier, \n      sortable: true, \n      width: '150px',\n      cell: row => <EllipsisCell value={row.legal_identifier} maxWidth=\"150px\" />\n    },\n    { \n      name: 'Nom légal', \n      selector: row => row.legal_name, \n      sortable: true,\n      cell: row => <EllipsisCell value={row.legal_name} />\n    },\n    { \n      name: 'Adresse', \n      selector: row => row.address, \n      sortable: true,\n      cell: row => <EllipsisCell value={row.address} />\n    },\n    { \n      name: 'Code postal', \n      selector: row => row.postal_code, \n      sortable: true, \n      width: '120px',\n      cell: row => <EllipsisCell value={row.postal_code} maxWidth=\"120px\" />\n    },\n    { \n      name: 'Ville', \n      selector: row => row.city, \n      sortable: true,\n      cell: row => <EllipsisCell value={row.city} />\n    },\n    { \n      name: 'Pays', \n      selector: row => row.country_code, \n      sortable: true, \n      width: '100px',\n      cell: row => <EllipsisCell value={row.country_code} maxWidth=\"100px\" />\n    },\n    { \n      name: 'Email', \n      selector: row => row.contact_email, \n      sortable: true, \n      width: '200px',\n      cell: row => <EllipsisCell value={row.contact_email} maxWidth=\"200px\" />\n    },\n    { \n      name: 'Téléphone', \n      selector: row => row.phone_number || '', \n      sortable: true, \n      width: '120px',\n      cell: row => <EllipsisCell value={row.phone_number || ''} maxWidth=\"120px\" />\n    },\n  ];\n}\n"],"mappings":"AAYQ;AAXR,OAAO,WAAW;AAClB,SAAS,mBAAmB;AAC5B,OAAO,kBAAkB;AAEzB,wBAAwB,mBAAmB;AACzC,QAAM,WAAW,YAAY;AAE7B,SAAO;AAAA,IACL;AAAA,MACE,MAAM;AAAA,MACN,MAAM,SACJ,uBAAC,YAAO,WAAU,cAAa,SAAS,MAAM,SAAS,YAAY,IAAI,EAAE,EAAE,GAAG,kBAA9E;AAAA;AAAA;AAAA;AAAA,aAEA;AAAA,MAEF,gBAAgB;AAAA,MAChB,OAAO;AAAA,IACT;AAAA,IACA;AAAA,MACE,MAAM;AAAA,MACN,UAAU,SAAO,IAAI;AAAA,MACrB,UAAU;AAAA,MACV,OAAO;AAAA,MACP,MAAM,SAAO,uBAAC,gBAAa,OAAO,IAAI,kBAAkB,UAAS,WAApD;AAAA;AAAA;AAAA;AAAA,aAA4D;AAAA,IAC3E;AAAA,IACA;AAAA,MACE,MAAM;AAAA,MACN,UAAU,SAAO,IAAI;AAAA,MACrB,UAAU;AAAA,MACV,MAAM,SAAO,uBAAC,gBAAa,OAAO,IAAI,cAAzB;AAAA;AAAA;AAAA;AAAA,aAAqC;AAAA,IACpD;AAAA,IACA;AAAA,MACE,MAAM;AAAA,MACN,UAAU,SAAO,IAAI;AAAA,MACrB,UAAU;AAAA,MACV,MAAM,SAAO,uBAAC,gBAAa,OAAO,IAAI,WAAzB;AAAA;AAAA;AAAA;AAAA,aAAkC;AAAA,IACjD;AAAA,IACA;AAAA,MACE,MAAM;AAAA,MACN,UAAU,SAAO,IAAI;AAAA,MACrB,UAAU;AAAA,MACV,OAAO;AAAA,MACP,MAAM,SAAO,uBAAC,gBAAa,OAAO,IAAI,aAAa,UAAS,WAA/C;AAAA;AAAA;AAAA;AAAA,aAAuD;AAAA,IACtE;AAAA,IACA;AAAA,MACE,MAAM;AAAA,MACN,UAAU,SAAO,IAAI;AAAA,MACrB,UAAU;AAAA,MACV,MAAM,SAAO,uBAAC,gBAAa,OAAO,IAAI,QAAzB;AAAA;AAAA;AAAA;AAAA,aAA+B;AAAA,IAC9C;AAAA,IACA;AAAA,MACE,MAAM;AAAA,MACN,UAAU,SAAO,IAAI;AAAA,MACrB,UAAU;AAAA,MACV,OAAO;AAAA,MACP,MAAM,SAAO,uBAAC,gBAAa,OAAO,IAAI,cAAc,UAAS,WAAhD;AAAA;AAAA;AAAA;AAAA,aAAwD;AAAA,IACvE;AAAA,IACA;AAAA,MACE,MAAM;AAAA,MACN,UAAU,SAAO,IAAI;AAAA,MACrB,UAAU;AAAA,MACV,OAAO;AAAA,MACP,MAAM,SAAO,uBAAC,gBAAa,OAAO,IAAI,eAAe,UAAS,WAAjD;AAAA;AAAA;AAAA;AAAA,aAAyD;AAAA,IACxE;AAAA,IACA;AAAA,MACE,MAAM;AAAA,MACN,UAAU,SAAO,IAAI,gBAAgB;AAAA,MACrC,UAAU;AAAA,MACV,OAAO;AAAA,MACP,MAAM,SAAO,uBAAC,gBAAa,OAAO,IAAI,gBAAgB,IAAI,UAAS,WAAtD;AAAA;AAAA;AAAA;AAAA,aAA8D;AAAA,IAC7E;AAAA,EACF;AACF;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"d823e566645b5e8dba315659fec1b1a880c10216"}}