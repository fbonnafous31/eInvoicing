     placeholder=\"Ex: Erreur de saisie, Client a annulé...\"\n            />\n          </Form.Group>\n        </Modal.Body>\n        <Modal.Footer>\n          <Button variant=\"secondary\" onClick={() => setShowModal(false)}>\n            Annuler\n          </Button>\n          <Button variant=\"danger\" onClick={handleConfirm}>\n            Confirmer l'annulation\n          </Button>\n        </Modal.Footer>\n      </Modal>\n    </>\n  );\n}"],"mappings":"AAiBI,mBACE,cADF;AAjBJ,OAAO,SAAS,gBAAgB;AAChC,SAAS,OAAO,QAAQ,YAAY;AAEpC,wBAAwB,oBAAoB,EAAE,UAAU,WAAW,UAAU,GAAG;AAC9E,QAAM,CAAC,WAAW,YAAY,IAAI,SAAS,KAAK;AAChD,QAAM,CAAC,QAAQ,SAAS,IAAI,SAAS,EAAE;AAEvC,QAAM,gBAAgB,MAAM;AAC1B,QAAI,CAAC,OAAO,KAAK,GAAG;AAClB,YAAM,uCAAuC;AAC7C;AAAA,IACF;AACA,aAAS,MAAM;AACf,iBAAa,KAAK;AAAA,EACpB;AAEA,SACE,mCACE;AAAA;AAAA,MAAC;AAAA;AAAA,QACC,MAAK;AAAA,QACL,WAAU;AAAA,QACV,SAAS,MAAM,aAAa,IAAI;AAAA,QACjC;AAAA;AAAA,UACI;AAAA;AAAA;AAAA,MALL;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,IAMA;AAAA,IAEA,uBAAC,SAAM,MAAM,WAAW,QAAQ,MAAM,aAAa,KAAK,GAAG,UAAQ,MACjE;AAAA,6BAAC,MAAM,QAAN,EAAa,aAAW,MACvB,iCAAC,MAAM,OAAN,EAAY,kCAAb;AAAA;AAAA;AAAA;AAAA,aAA+B,KADjC;AAAA;AAAA;AAAA;AAAA,aAEA;AAAA,MACA,uBAAC,MAAM,MAAN,EACC,iCAAC,KAAK,OAAL,EACC;AAAA,+BAAC,KAAK,OAAL,EAAW,qCAAZ;AAAA;AAAA;AAAA;AAAA,eAAiC;AAAA,QACjC;AAAA,UAAC,KAAK;AAAA,UAAL;AAAA,YACC,MAAK;AAAA,YACL,OAAO;AAAA,YACP,UAAU,CAAC,MAAM,UAAU,EAAE,OAAO,KAAK;AAAA,YACzC,aAAY;AAAA;AAAA,UAJd;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,QAKA;AAAA,WAPF;AAAA;AAAA;AAAA;AAAA,aAQA,KATF;AAAA;AAAA;AAAA;AAAA,aAUA;AAAA,MACA,uBAAC,MAAM,QAAN,EACC;AAAA,+BAAC,UAAO,SAAQ,aAAY,SAAS,MAAM,aAAa,KAAK,GAAG,uBAAhE;AAAA;AAAA;AAAA;AAAA,eAEA;AAAA,QACA,uBAAC,UAAO,SAAQ,UAAS,SAAS,eAAe,sCAAjD;AAAA;AAAA;AAAA;AAAA,eAEA;AAAA,WANF;AAAA;AAAA;AAAA;AAAA,aAOA;AAAA,SAtBF;AAAA;AAAA;AAAA;AAAA,WAuBA;AAAA,OAhCF;AAAA;AAAA;AAAA;AAAA,SAiCA;AAEJ;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"df9964346210b84d8dae7d81e83b877cfaacc67d"}}