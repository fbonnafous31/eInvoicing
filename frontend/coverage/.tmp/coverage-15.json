{"start":{"line":70,"column":17},"end":{"line":70,"column":35}},{"start":{"line":70,"column":38},"end":{"line":70,"column":62}}],"line":70},"4":{"loc":{"start":{"line":78,"column":20},"end":{"line":78,"column":60}},"type":"cond-expr","locations":[{"start":{"line":78,"column":31},"end":{"line":78,"column":45}},{"start":{"line":78,"column":48},"end":{"line":78,"column":60}}],"line":78}},"s":{"0":1,"1":6,"2":6,"3":6,"4":2,"5":2,"6":6,"7":2},"f":{"0":6,"1":2,"2":2},"b":{"0":[1,1],"1":[2,4],"2":[2,4],"3":[2,4],"4":[2,4]},"inputSourceMap":{"version":3,"sources":["/home/francois/dev/eInvoicing/frontend/src/LoginPage.jsx"],"sourcesContent":["import React, { useState } from \"react\";\nimport { useAuth0 } from \"@auth0/auth0-react\";\nimport { getEnv } from \"./utils/getEnv\";\nimport './LoginPage.css';\n\nconst LoginPage = () => {\n  const { loginWithRedirect } = useAuth0();\n  const [isSignup, setIsSignup] = useState(false);\n\n  const handleAuth = () => {\n    const env = getEnv(); // récupère les variables Auth0 selon l'environnement\n\n    loginWithRedirect({\n      screen_hint: isSignup ? \"signup\" : \"login\",\n      authorizationParams: {\n        audience: env.VITE_AUTH0_AUDIENCE, // centralisé via getEnv\n        scope: \"openid profile email\",\n      },\n    });\n  };\n\n  return (\n    <div className=\"login-page d-flex justify-content-center align-items-center vh-100\">\n      <div className=\"card shadow p-5 text-start login-card\">\n        \n        {/* Logo + Titre */}\n        <div className=\"d-flex align-items-center mb-3 logo-title\">\n          <img\n            src=\"/logo.png\"\n            alt=\"eInvoicing Logo\"\n            className=\"logo\"\n          />\n          <h1 className=\"fw-bold mb-0\">eInvoicing</h1>\n        </div>\n\n        <p className=\"text-secondary mb-4 slogan\">\n          {isSignup \n            ? \"Créez votre compte et commencez à gérer vos factures facilement\" \n            : \"Connectez-vous pour accéder à vos factures et documents\"}\n        </p>\n\n        <button\n          className=\"btn btn-primary btn-lg w-100 mb-3\"\n          onClick={handleAuth}\n        >\n          {isSignup ? \"S'inscrire\" : \"Se connecter\"}\n        </button>\n\n        <div className=\"text-muted mt-2\" style={{ fontSize: '0.9rem' }}>\n          {isSignup ? \"Déjà un compte ?\" : \"Pas encore de compte ?\"}{\" \"}\n          <span\n            className=\"text-primary fw-bold\"\n            style={{ cursor: \"pointer\" }}\n            onClick={() => setIsSignup(!isSignup)}\n          >\n            {isSignup ? \"Se connecter\" : \"S'inscrire\"}\n          </span>\n        </div>\n      </div>\n    </div>\n  );\n};\n\nexport default LoginPage;\n"],"mappings":"AA2BU;AA3BV,OAAO,SAAS,gBAAgB;AAChC,SAAS,gBAAgB;AACzB,SAAS,cAAc;AACvB,OAAO;AAEP,MAAM,YAAY,MAAM;AACtB,QAAM,EAAE,kBAAkB,IAAI,SAAS;AACvC,QAAM,CAAC,UAAU,WAAW,IAAI,SAAS,KAAK;AAE9C,QAAM,aAAa,MAAM;AACvB,UAAM,MAAM,OAAO;AAEnB,sBAAkB;AAAA,MAChB,aAAa,WAAW,WAAW;AAAA,MACnC,qBAAqB;AAAA,QACnB,UAAU,IAAI;AAAA;AAAA,QACd,OAAO;AAAA,MACT;AAAA,IACF,CAAC;AAAA,EACH;AAEA,SACE,uBAAC,SAAI,WAAU,sEACb,iCAAC,SAAI,WAAU,yCAGb;AAAA,2BAAC,SAAI,WAAU,6CACb;AAAA;AAAA,QAAC;AAAA;AAAA,UACC,KAAI;AAAA,UACJ,KAAI;AAAA,UACJ,WAAU;AAAA;AAAA,QAHZ;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,MAIA;AAAA,MACA,uBAAC,QAAG,WAAU,gBAAe,0BAA7B;AAAA;AAAA;AAAA;AAAA,aAAuC;AAAA,SANzC;AAAA;AAAA;AAAA;AAAA,WAOA;AAAA,IAEA,uBAAC,OAAE,WAAU,8BACV,qBACG,oEACA,6DAHN;AAAA;AAAA;AAAA;AAAA,WAIA;AAAA,IAEA;AAAA,MAAC;AAAA;AAAA,QACC,WAAU;AAAA,QACV,SAAS;AAAA,QAER,qBAAW,eAAe;AAAA;AAAA,MAJ7B;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,IAKA;AAAA,IAEA,uBAAC,SAAI,WAAU,mBAAkB,OAAO,EAAE,UAAU,SAAS,GAC1D;AAAA,iBAAW,qBAAqB;AAAA,MAA0B;AAAA,MAC3D;AAAA,QAAC;AAAA;AAAA,UACC,WAAU;AAAA,UACV,OAAO,EAAE,QAAQ,UAAU;AAAA,UAC3B,SAAS,MAAM,YAAY,CAAC,QAAQ;AAAA,UAEnC,qBAAW,iBAAiB;AAAA;AAAA,QAL/B;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,MAMA;AAAA,SARF;AAAA;AAAA;AAAA;AAAA,WASA;AAAA,OAlCF;AAAA;AAAA;AAAA;AAAA,SAmCA,KApCF;AAAA;AAAA;AAAA;AAAA,SAqCA;AAEJ;AAEA,eAAe;