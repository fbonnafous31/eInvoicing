Change = (field) => (val) => handleChange(field, val);\n\n  return (\n    <>\n      <InputEmail\n        id=\"contact_email\"\n        name=\"contact_email\"\n        label=\"Email\"\n        value={formData.contact_email}\n        onChange={handleFieldChange('contact_email')}\n        onBlur={() => handleBlur('contact_email')}\n        touched={touched.contact_email}\n        disabled={disabled}\n        required={false}\n      />\n\n      <InputPhone\n        id=\"phone_number\"\n        name=\"phone_number\"\n        label=\"Téléphone\"\n        value={formData.phone_number}\n        onChange={handleFieldChange('phone_number')}\n        onBlur={() => handleBlur('phone_number')}\n        touched={touched.phone_number}\n        disabled={disabled}\n        required={false}\n      />\n    </>\n  );\n}\n"],"mappings":"AAQI,mBACE,cADF;AAPJ,OAAO,WAAW;AAClB,SAAS,YAAY,kBAAkB;AAEvC,wBAAwB,cAAc,EAAE,UAAU,SAAS,cAAc,YAAY,SAAS,GAAG;AAC/F,QAAM,oBAAoB,CAAC,UAAU,CAAC,QAAQ,aAAa,OAAO,GAAG;AAErE,SACE,mCACE;AAAA;AAAA,MAAC;AAAA;AAAA,QACC,IAAG;AAAA,QACH,MAAK;AAAA,QACL,OAAM;AAAA,QACN,OAAO,SAAS;AAAA,QAChB,UAAU,kBAAkB,eAAe;AAAA,QAC3C,QAAQ,MAAM,WAAW,eAAe;AAAA,QACxC,SAAS,QAAQ;AAAA,QACjB;AAAA,QACA,UAAU;AAAA;AAAA,MATZ;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,IAUA;AAAA,IAEA;AAAA,MAAC;AAAA;AAAA,QACC,IAAG;AAAA,QACH,MAAK;AAAA,QACL,OAAM;AAAA,QACN,OAAO,SAAS;AAAA,QAChB,UAAU,kBAAkB,cAAc;AAAA,QAC1C,QAAQ,MAAM,WAAW,cAAc;AAAA,QACvC,SAAS,QAAQ;AAAA,QACjB;AAAA,QACA,UAAU;AAAA;AAAA,MATZ;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,IAUA;AAAA,OAvBF;AAAA;AAAA;AAAA;AAAA,SAwBA;AAEJ;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"e243a2d44f93b633dc108860ced7c9b252e36248"}}