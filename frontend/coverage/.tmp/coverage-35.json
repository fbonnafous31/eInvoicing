View, invoice, canEditAdditional }) {\n  const invoiceService = useInvoiceService();\n\n  useEffect(() => {\n    console.log(\"📎 SupportingDocs - current attachments:\", data);\n  }, [data]);\n\n  // ----------------------\n  // Gestion justificatif principal\n  // ----------------------\n  const mainAttachment = data.find(a => a.attachment_type === \"main\" && !a.generated);\n  const additionalAttachments = data.filter(a => a.attachment_type === \"additional\");\n\n  const handleMainChange = (e) => {\n    const file = e.target.files[0];\n    if (!file) return;\n\n    const mainFile = {\n      file_name: file.name,\n      raw_file: file,\n      attachment_type: \"main\",\n    };\n\n    const newData = [mainFile, ...data.filter(a => a.attachment_type !== \"main\" && !a.generated)];\n    console.log(\"📎 Ajout justificatif principal:\", mainFile);\n    onChange(newData);\n  };\n\n  const handleAdditionalChange = (e) => {\n    const files = Array.from(e.target.files).map(f => ({\n      file_name: f.name,\n      raw_file: f,\n      attachment_type: \"additional\",\n    }));\n\n    console.log(\"📎 Ajout justificatifs additionnels:\", files);\n    onChange([...data, ...files]);\n  };\n\n  const removeFile = (index, type) => {\n    let newData;\n    if (type === \"main\") {\n      newData = data.filter(a => a.attachment_type !== \"main\" && !a.generated);\n    } else {\n      let count = -1;\n      newData = data.filter(a => {\n        if (a.attachment_type === \"additional\") count++;\n        return !(type === \"additional\" && count === index);\n      });\n    }\n    console.log(`🗑️ Suppression fichier ${type} index ${index}`);\n    onChange(newData);\n  };\n\n  const handleGeneratePdf = async () => {\n    if (!invoice) return console.error(\"❌ invoice missing\");\n\n    try {\n      const blob = await invoiceService.fetchInvoicePdf(invoice);\n      const url = URL.createObjectURL(blob);\n\n      const link = document.createElement(\"a\");\n      link.href = url;\n      link.download = `facture_${invoice.header?.invoice_number || \"preview\"}.pdf`;\n      document.body.appendChild(link);\n      link.click();\n      link.remove();\n\n      URL.revokeObjectURL(url);\n      console.log(\"✅ PDF généré avec succès\");\n    } catch (err) {\n      console.error(\"❌ Erreur génération PDF :\", err);\n    }\n  };\n\n  return (\n    <div className=\"card p-3 mb-3\">\n      <h5>Justificatifs</h5>\n\n      {/* Justificatif principal */}\n      <div className=\"mb-3\">\n        <label>Justificatif principal (format PDF) *</label>\n\n        {!hideLabelsInView && (\n          <div className=\"mt-3 pb-3\">\n            <button\n              type=\"button\"\n              className=\"btn btn-primary btn-sm\"\n              disabled={disabled}\n              onClick={handleGeneratePdf}\n            >\n              {mainAttachment ? \"Regénérer le PDF\" : \"Générer le PDF\"}\n            </button>\n          </div>\n        )}\n\n        {!hideLabelsInView && (\n          <input\n            type=\"file\"\n            onChange={handleMainChange}\n            className=\"form-control\"\n            disabled={canEditAdditional}\n          />\n        )}\n\n        {mainAttachment && (\n          <div className=\"mt-1 d-flex justify-content-between align-items-center\">\n            <span>{mainAttachment.file_name}</span>\n            {!hideLabelsInView && (\n              <SmallDeleteButton\n                onClick={() => removeFile(0, \"main\")}\n                disabled={canEditAdditional || disabled}\n              />\n            )}\n          </div>\n        )}\n      </div>\n\n      {/* Justificatifs additionnels */}\n      <div className=\"mb-3\">\n        <label>Justificatifs additionnels</label>\n        {!hideLabelsInView && (\n          <input\n            type=\"file\"\n            multiple\n            onChange={handleAdditionalChange}\n            className=\"form-control mb-2\"\n            disabled={disabled}\n          />\n        )}\n        <ul>\n          {additionalAttachments.map((file, index) => (\n            <li key={index} className=\"d-flex justify-content-between align-items-center mb-2\">\n              <span>{file.file_name || \"Nom non disponible\"}</span>\n              {!hideLabelsInView && (\n                <SmallDeleteButton\n                  onClick={() => removeFile(index, \"additional\")}\n                  disabled={canEditAdditional}\n                />\n              )}\n            </li>\n          ))}\n        </ul>\n      </div>\n    </div>\n  );\n}\n"],"mappings":"AAkFM;AAlFN,OAAO,SAAS,iBAAiB;AACjC,SAAS,yBAAyB;AAClC,SAAS,eAAe;AACxB,SAAS,yBAAyB;AAElC,wBAAwB,eAAe,EAAE,MAAM,UAAU,UAAU,kBAAkB,SAAS,kBAAkB,GAAG;AACjH,QAAM,iBAAiB,kBAAkB;AAEzC,YAAU,MAAM;AACd,YAAQ,IAAI,4CAA4C,IAAI;AAAA,EAC9D,GAAG,CAAC,IAAI,CAAC;AAKT,QAAM,iBAAiB,KAAK,KAAK,OAAK,EAAE,oBAAoB,UAAU,CAAC,EAAE,SAAS;AAClF,QAAM,wBAAwB,KAAK,OAAO,OAAK,EAAE,oBAAoB,YAAY;AAEjF,QAAM,mBAAmB,CAAC,MAAM;AAC9B,UAAM,OAAO,EAAE,OAAO,MAAM,CAAC;AAC7B,QAAI,CAAC,KAAM;AAEX,UAAM,WAAW;AAAA,MACf,WAAW,KAAK;AAAA,MAChB,UAAU;AAAA,MACV,iBAAiB;AAAA,IACnB;AAEA,UAAM,UAAU,CAAC,UAAU,GAAG,KAAK,OAAO,OAAK,EAAE,oBAAoB,UAAU,CAAC,EAAE,SAAS,CAAC;AAC5F,YAAQ,IAAI,oCAAoC,QAAQ;AACxD,aAAS,OAAO;AAAA,EAClB;AAEA,QAAM,yBAAyB,CAAC,MAAM;AACpC,UAAM,QAAQ,MAAM,KAAK,EAAE,OAAO,KAAK,EAAE,IAAI,QAAM;AAAA,MACjD,WAAW,EAAE;AAAA,MACb,UAAU;AAAA,MACV,iBAAiB;AAAA,IACnB,EAAE;AAEF,YAAQ,IAAI,wCAAwC,KAAK;AACzD,aAAS,CAAC,GAAG,MAAM,GAAG,KAAK,CAAC;AAAA,EAC9B;AAEA,QAAM,aAAa,CAAC,OAAO,SAAS;AAClC,QAAI;AACJ,QAAI,SAAS,QAAQ;AACnB,gBAAU,KAAK,OAAO,OAAK,EAAE,oBAAoB,UAAU,CAAC,EAAE,SAAS;AAAA,IACzE,OAAO;AACL,UAAI,QAAQ;AACZ,gBAAU,KAAK,OAAO,OAAK;AACzB,YAAI,EAAE,oBAAoB,aAAc;AACxC,eAAO,EAAE,SAAS,gBAAgB,UAAU;AAAA,MAC9C,CAAC;AAAA,IACH;AACA,YAAQ,IAAI,2BAA2B,IAAI,UAAU,KAAK,EAAE;AAC5D,aAAS,OAAO;AAAA,EAClB;AAEA,QAAM,oBAAoB,YAAY;AACpC,QAAI,CAAC,QAAS,QAAO,QAAQ,MAAM,mBAAmB;AAEtD,QAAI;AACF,YAAM,OAAO,MAAM,eAAe,gBAAgB,OAAO;AACzD,YAAM,MAAM,IAAI,gBAAgB,IAAI;AAEpC,YAAM,OAAO,SAAS,cAAc,GAAG;AACvC,WAAK,OAAO;AACZ,WAAK,WAAW