     return;\n    }\n    onCancel(reason);\n    setShowModal(false);\n  };\n\n  return (\n    <>\n      <button\n        type=\"button\"\n        className=\"btn btn-secondary\"\n        onClick={() => setShowModal(true)}\n      >\n        ❌ {children}\n      </button>\n\n      <Modal show={showModal} onHide={() => setShowModal(false)} centered>\n        <Modal.Header closeButton>\n          <Modal.Title>Annuler la facture</Modal.Title>\n        </Modal.Header>\n        <Modal.Body>\n          <Form.Group>\n            <Form.Label>Motif de l'annulation</Form.Label>\n            <Form.Control\n              type=\"text\"\n              value={reason}\n              onChange={(e) => setReason(e.target.value)}\n              placeholder=\"Ex: Erreur de saisie, Client a annulé...\"\n            />\n          </Form.Group>\n        </Modal.Body>\n        <Modal.Footer>\n          <Button variant=\"secondary\" onClick={() => setShowModal(false)}>\n            Annuler\n          </Button>\n          <Button variant=\"danger\" onClick={handleConfirm}>\n            Confirmer l'annulation\n          </Button>\n        </Modal.Footer>\n      </Modal>\n    </>\n  );\n}"],"mappings":"AAiBI,mBACE,cADF;AAjBJ,OAAO,SAAS,gBAAgB;AAChC,SAAS,OAAO,QAAQ,YAAY;AAEpC,wBAAwB,oBAAoB,EAAE,UAAU,WAAW,UAAU,GAAG;AAC9E,QAAM,CAAC,WAAW,YAAY,IAAI,SAAS,KAAK;AAChD,QAAM,CAAC,QAAQ,SAAS,IAAI,SAAS,EAAE;AAEvC,QAAM,gBAAgB,MAAM;AAC1B,QAAI,CAAC,OAAO,KAAK,GAAG;AAClB,YAAM,uCAAuC;AAC7C;AAAA,IACF;AACA,aAAS,MAAM;AACf,iBAAa,KAAK;AAAA,EACpB;AAEA,SACE,mCACE;AAAA;AAAA,MAAC;AAAA;AAAA,QACC,MAAK;AAAA,QACL,WAAU;AAAA,QACV,SAAS,MAAM,aAAa,IAAI;AAAA,QACjC;AAAA;AAAA,UACI;AAAA;AAAA;AAAA,MALL;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,IAMA;AAAA,IAEA,uBAAC,SAAM,MAAM,WAAW,QAAQ,MAAM,aAAa,KAAK,GAAG,UAAQ,MACjE;AAAA,6BAAC,MAAM,QAAN,EAAa,aAAW,MACvB,iCAAC,MAAM,OAAN,EAAY,kCAAb;AAAA;AAAA;AAAA;AAAA,aAA+B,KADjC;AAAA;AAAA;AAAA;AAAA,aAEA;AAAA,MACA,uBAAC,MAAM,MAAN,EACC,iCAAC,KAAK,OAAL,EACC;AAAA,+BAAC,KAAK,OAAL,EAAW,qCAAZ;AAAA;AAAA;AAAA;AAAA,eAAiC;AA