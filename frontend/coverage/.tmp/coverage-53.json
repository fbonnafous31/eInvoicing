 nom du composant réel\nconst getComponentName = (element) => {\n  // Si l'élément est enveloppé dans un HOC comme RequireSeller\n  if (element?.props?.children?.type?.name) {\n    return element.props.children.type.name;\n  }\n  // Sinon on retourne le nom du composant directement\n  return element.type.name;\n};\n\nfunction App() {\n  const fullWidthStaticRoutes = [\"/clients\", \"/sellers\", \"/invoices\", \"/\"];\n\n  return (\n    <Routes>\n      {/* Page publique */}\n      <Route path=\"/login\" element={<LoginPage />} />\n\n      {/* Routes protégées */}\n      {routes.map(({ path, element }) => {\n        if (path === \"/login\") return null;\n\n        let isFullWidth = false;\n\n        // Routes statiques\n        if (fullWidthStaticRoutes.includes(path)) {\n          isFullWidth = true;\n        }\n\n        // Routes dynamiques ciblées\n        if (path === \"/invoices/:id/view\") {\n          isFullWidth = true;\n        }\n\n        return (\n          <Route\n            key={path}\n            path={path}\n            element={\n              <PrivateRoute>\n                <Layout fluid={isFullWidth}>{element}</Layout>\n              </PrivateRoute>\n            }\n          />\n        );\n      })}\n    </Routes>\n  );\n}\n\nexport default App;\n"],"mappings":"AAYI,mBACE,cADF;AAXJ,OAAO,WAAW;AAClB,SAAS,QAAQ,aAAa;AAE9B,OAAO,YAAY;AACnB,OAAO,YAAY;AACnB,OAAO,kBAAkB;AACzB,OAAO,eAAe;AAGtB,SAAS,OAAO,EAAE,UAAU,QAAQ,MAAM,GAAG;AAC3C,SACE,mCACE;AAAA,2BAAC,YAAD;AAAA;AAAA;AAAA;AAAA,WAAQ;AAAA,IACR,uBAAC,UAAK,WAAW,QAAQ,8BAA8B,kBACpD,YADH;AAAA;AAAA;AAAA;AAAA,WAEA;AAAA,OAJF;AAAA;AAAA;AAAA;AAAA,SAKA;AAEJ;AAGA,MAAM,mBAAmB,CAAC,YAAY;AAEpC,MAAI,SAAS,OAAO,UAAU,MAAM,MAAM;AACxC,WAAO,QAAQ,MAAM,SAAS,KAAK;AAAA,EACrC;AAEA,SAAO,QAAQ,KAAK;AACtB;AAEA,SAAS,MAAM;AACb,QAAM,wBAAwB,CAAC,YAAY,YAAY,aAAa,GAAG;AAEvE,SACE,uBAAC,UAEC;AAAA,2BAAC,SAAM,MAAK,UAAS,SAAS,uBAAC,eAAD;AAAA;AAAA;AAAA;AAAA,WAAW,KAAzC;AAAA;AAAA;AAAA;AAAA,WAA6C;AAAA,IAG5C,OAAO,IAAI,CAAC,EAAE,MAAM,QAAQ,MAAM;AACjC,UAAI,