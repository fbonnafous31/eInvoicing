ontent":["// frontend/src/pages/sellers/ProfilePage.jsx\nimport React, { useEffect, useState } from \"react\";\nimport SellerDetail from \"./SellerDetail\";\nimport { useSellerService } from \"@/services/sellers\";\n\nexport default function ProfilePage() {\n  const [sellerId, setSellerId] = useState(null);\n  const [loading, setLoading] = useState(true);\n  const [error, setError] = useState(null);\n\n  const { fetchMySeller } = useSellerService();\n\n  useEffect(() => {\n    let isMounted = true;\n\n    const loadSeller = async () => {\n      console.log(\"[ProfilePage] → Début loadSeller\", { loading, sellerId, error });\n      try {\n        const seller = await fetchMySeller();\n        console.log(\"[ProfilePage] ← seller reçu :\", seller);\n\n        if (!seller || !seller.id) {\n          console.warn(\"[ProfilePage] Seller invalide :\", seller);\n          if (isMounted) setError(\"Profil invalide ou incomplet\");\n          return;\n        }\n\n        if (isMounted) {\n          console.log(\"[ProfilePage] Mise à jour du sellerId :\", seller.id);\n          setSellerId(seller.id);\n        }\n      } catch (err) {\n        console.error(\"[ProfilePage] Erreur fetchMySeller :\", err);\n        if (isMounted) setError(err.message || \"Impossible de récupérer le profil\");\n      } finally {\n        if (isMounted) {\n          console.log(\"[ProfilePage] ← loadSeller terminé, loading → false\");\n          setLoading(false);\n        }\n      }\n    };\n\n    loadSeller();\n\n    return () => { \n      console.log(\"[ProfilePage] → Composant démonté, isMounted = false\");\n      isMounted = false; \n    };\n  // eslint-disable-next-line react-hooks/exhaustive-deps\n  }, [fetchMySeller]);\n\n  console.log(\"[ProfilePage] Rendu avec state :\", { loading, error, sellerId });\n\n  if (loading) return <p>Chargement...</p>;\n  if (error) return <p className=\"text-danger\">{error}</p>;\n  if (!sellerId) return <p>Aucun profil trouvé</p>;\n\n  // On réutilise SellerDetail en injectant l'id\n  return <SellerDetail sellerId={sellerId} />;\n}\n"],"mappings":"AAqDsB;AApDtB,OAAO,SAAS,WAAW,gBAAgB;AAC3C,OAAO,kBAAkB;AACzB,SAAS,wBAAwB;AAEjC,wBAAwB,cAAc;AACpC,QAAM,CAAC,UAAU,WAAW,IAAI,SAAS,IAAI;AAC7C,QAAM,CAAC,SAAS,UAAU,IAAI,SAAS,IAAI;AAC3C,QAAM,CAAC,OAAO,QAAQ,IAAI,SAAS,IAAI;AAEvC,QAAM,EAAE,cAAc,IAAI,iBAAiB;AAE3C,YAAU,MAAM;AACd,QAAI,YAAY;AAEhB,UAAM,aAAa,YAAY;AAC7B,cAAQ,IAAI,oCAAoC,EAAE,SAAS,UAAU,MAAM,CAAC;AAC5E,UAAI;AACF,cAAM,SAAS,MAAM,cAAc;AACnC,gBAAQ,IAAI,iCAAiC,MAAM;AAEnD,YAAI,CAAC,UAAU,CAAC,OAAO,IAAI;AACzB,kBAAQ,KAAK,mCAAmC,MAAM;AACtD,cAAI,UAAW,UAAS,8BAA8B;AACtD;AAAA,QACF;AAEA,YAAI,WAAW;AACb,kBAAQ,IAAI,2CAA2C,OAAO,EAAE;AAChE,sBAAY,OAAO,EAAE;AAAA,QACvB;AAAA,MACF,SAAS,KAAK;AACZ,gBAAQ,MAAM,wCAAwC,GAAG;AACzD,YAAI,UAAW,UAAS,IAAI,WAAW,mCAAmC;AAAA,MAC5E,UAAE;AACA,YAAI,WAAW;AACb,kBAAQ,IAAI,qDAAqD;AACjE,qBAAW,KAAK;AAAA,QAClB;AAAA,MACF;AAAA,IACF;AAEA,eAAW;AAEX,WAAO,MAAM;AACX,cAAQ,IAAI,sDAAsD;AAClE,kBAAY;AAAA,IACd;AAAA,EAEF,GAAG,CAAC,aAAa,CAAC;AAElB,UAAQ,IAAI,oCAAoC,EAAE,SAAS,OAAO,SAAS,CAAC;AAE5E,MAAI,QAAS,QAAO,uBAAC,OAAE,6BAAH;AAAA;AAAA;AAAA;AAAA,SAAgB;AACpC,MAAI,MAAO,QAAO,uBAAC,OAAE,WAAU,eAAe,mBAA5B;AAAA;AAAA;AAAA;AAAA,SAAkC;AACpD,MAAI,CAAC,SAAU,QAAO,uBAAC,OAAE,mCAAH;AAAA;AAAA;AAAA;AAAA,SAAsB;AAG5C,SAAO,uBAAC,gBAAa,YAAd;AAAA;AAAA;AAAA;AAAA,SAAkC;AAC3C;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"460b9e2fba1d93abed757d5ddf2257e2c84b8737"}}