s(numPages);\n    setPageNumber(1);\n  };\n\n  const onDocumentLoadError = (err) => {\n    console.error(\"Erreur de chargement du PDF:\", err);\n    console.log(\"Nom du fichier PDF transmis:\", fileUrl);\n    setError('Erreur de chargement du PDF');\n  };\n\n  if (!fileUrl) return <div>Aucun PDF disponible</div>;\n\n  return (\n    <div ref={containerRef} className=\"d-flex flex-column\" style={{ width: \"100%\", height: \"100%\", border: \"1px solid #ccc\" }}>\n      \n      {/* Contrôles PDF */}\n      <div className=\"d-flex justify-content-between align-items-center mb-2 p-2 bg-light border-bottom\">\n        {/* Navigation */}\n        <ButtonGroup size=\"sm\">\n          <Button onClick={() => setPageNumber(p => Math.max(p - 1, 1))} disabled={pageNumber <= 1}>⬅️</Button>\n          <Button variant=\"light\" disabled>{pageNumber} / {numPages || \"?\"}</Button>\n          <Button onClick={() => setPageNumber(p => Math.min(p + 1, numPages))} disabled={pageNumber >= numPages}>➡️</Button>\n        </ButtonGroup>\n\n        {/* Zoom */}\n        <ButtonGroup size=\"sm\">\n          <Button onClick={() => setScale(s => Math.max(s - 0.1, 0.1))}>–</Button>\n          <Button variant=\"light\" disabled>{Math.round(scale * 100)}%</Button>\n          <Button onClick={() => setScale(s => s + 0.1)}>+</Button>\n        </ButtonGroup>\n\n        {/* Téléchargement */}\n        <Button href={fileUrl} target=\"_blank\" download={`facture_${invoiceId || \"unknown\"}.pdf`} variant=\"success\" size=\"sm\">\n          Télécharger ⬇️\n        </Button>\n      </div>\n\n      {/* PDF */}\n      <div style={{ flex: 1, overflow: \"auto\" }}>\n        {error && <div className=\"text-danger p-2\">{error}</div>}\n        <Document\n          file={fileUrl}\n          onLoadSuccess={onDocumentLoadSuccess}\n          onLoadError={onDocumentLoadError}\n        >\n          <Page pageNumber={pageNumber} width={width} scale={scale} />\n        </Document>\n      </div>\n    </div>\n  );\n};\n\nexport default PdfViewer;\n"],"mappings":"AAyCuB;AAzCvB,SAAS,UAAU,QAAQ,iBAAiB;AAC5C,SAAS,UAAU,MAAM,aAAa;AACtC,SAAS,QAAQ,mBAAmB;AACpC,OAAO;AACP,OAAO;AACP,OAAO,eAAe;AAMtB,MAAM,oBAAoB,YAAY;AAEtC,MAAM,YAAY,CAAC,EAAE,SAAS,UAAU,MAAM;AAC5C,QAAM,CAAC,UAAU,WAAW,IAAI,SAAS,IAAI;AAC7C,QAAM,CAAC,YAAY,aAAa,IAAI,SAAS,CAAC;AAC9C,QAAM,CAAC,OAAO,QAAQ,IAAI,SAAS,CAAG;AACtC,QAAM,CAAC,OAAO,QAAQ,IAAI,SAAS,IAAI;AACvC,QAAM,eAAe,OAAO,IAAI;AAChC,QAAM,CAAC,OAAO,QAAQ,IAAI,SAAS,CAAC;AAEpC,YAAU,MAAM;AACd,UAAM,eAAe,MAAM;AACzB,UAAI,aAAa,QAAS,UAAS,aAAa,QAAQ,WAAW;AAAA,IACrE;AACA,iBAAa;AACb,WAAO,iBAAiB,UAAU,YAAY;AAC9C,WAAO,MAAM,OAAO,oBAAoB,UAAU,YAAY;AAAA,EAChE,GAAG,CAAC,CAAC;AAEL,QAAM,wBAAwB,CAAC,EAAE,UAAAA,UAAS,MAAM;AAC9C,gBAAYA,SAAQ;AACpB,kBAAc,CAAC;AAAA,EACjB;AAEA,QAAM,sBAAsB,CAAC,QAAQ;AACnC,YAAQ,MAAM,gCAAgC,GAAG;AACjD,YAAQ,IAAI,gCAAgC,OAAO;AACnD,aAAS,6BAA6B;AAAA,EACxC;AAEA,MAAI,CAAC,QAAS,QAAO,uBAAC,SAAI,oCAAL;AAAA;AAAA;AAAA;AAAA,SAAyB;AAE9C,SACE,uBAAC,SAAI,KAAK,cAAc,WAAU,sBAAqB,OAAO,EAAE,OAAO,QAAQ,QAAQ,QAAQ,QAAQ,iBAAiB,GAGtH;AAAA,2BAAC,SAAI,WAAU,qFAEb;AAAA,6BAAC,eAAY,MAAK,MAChB;AAAA,+BAAC,UAAO,SAAS,MAAM,cAAc,OAAK,KAAK,IAAI,IAAI,GAAG,CAAC,CAAC,GAAG,UAAU,cAAc,GAAG,kBAA1F;AAAA;AAAA;AAAA;AAAA,eAA4F;AAAA,QAC5F,uBAAC,UAAO,SAAQ,SAAQ,UAAQ,MAAE;AAAA;AAAA,UAAW;AAAA,UAAI,YAAY;AAAA,aAA7D;AAAA;AAAA;AAAA;AAAA,eAAiE;AAAA,QACjE,uBAAC,UAAO,SAAS,MAAM,cAAc,OAAK,KAAK,IAAI,IAAI,GAAG,QAAQ,CAAC,GAAG,UAAU,cAAc,UAAU,kBAAxG;AAAA;AAAA;AAAA;AAAA,eAA0G;AAAA,WAH5G;AAAA;AAAA;AAAA;AAAA,aAIA;AAAA,MAGA,uBAAC,eAAY,MAAK,MAChB;AAAA,+BAAC,UAAO,SAAS,MAAM,SAAS,OAAK,KAAK,IAAI,IAAI,KAAK,GAAG,CAAC,GAAG,iBAA9D;AAAA;AAAA;AAAA;AAAA,eAA+D;AAAA,QAC/D,uBAAC,UAAO,SAAQ,SAAQ,UAAQ,MAAE;AAAA,eAAK,MAAM,QAAQ,GAAG;AAAA,UAAE;AAAA,aAA1D;AAAA;AAAA;AAAA;AAAA,eAA2D;AAAA,QAC3D,uBAAC,UAAO,SAAS,MAAM,SAAS,OAAK,IAAI,GAAG,GAAG,iBAA/C;AAAA;AAAA;AAAA;AAAA,eAAgD;AAAA,WAHlD;AAAA;AAAA;AAAA;AAAA,aAIA;AAAA,MAGA,uBAAC,UAAO,MAAM,SAAS,QAAO,UAAS,UAAU,WAAW,aAAa,SAAS,QAAQ,SAAQ,WAAU,MAAK,MAAK,8BAAtH;AAAA;AAAA;AAAA;AAAA,aAEA;AAAA,SAlBF;AAAA;AAAA;AAAA;AAAA,WAmBA;AAAA,IAGA,uBAA