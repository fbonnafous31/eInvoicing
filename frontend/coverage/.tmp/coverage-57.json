onst [errorMessage, setErrorMessage] = useState(\"\");\n\n  const { fetchMySeller, updateSeller } = useSellerService();\n\n  useEffect(() => {\n    if (!id) return;\n\n    let isMounted = true;\n\n    const loadSeller = async () => {\n      try {\n        const data = await fetchMySeller(id);\n        if (!data.contact_email) data.contact_email = \"\";\n        if (isMounted) setSeller(data);\n      } catch (err) {\n        console.error(err);\n        if (isMounted) setErrorMessage(\"Erreur lors du chargement du vendeur\");\n      }\n    };\n\n    loadSeller();\n\n    return () => {\n      isMounted = false;\n    };\n  }, [id, fetchMySeller]);\n\n  const handleUpdate = async (updatedData) => {\n    if (!updatedData.contact_email) updatedData.contact_email = \"\";\n\n    try {\n      const data = await updateSeller(id, updatedData);\n      if (!data.contact_email) data.contact_email = \"\";\n      setSeller(data);\n      setIsEditing(false);\n      setSuccessMessage(\"Vendeur mis à jour avec succès ! 🎉\");\n      window.scrollTo({ top: 0, behavior: \"smooth\" });\n      setTimeout(() => setSuccessMessage(\"\"), 2000);\n    } catch (err) {\n      console.error(err);\n      setErrorMessage(\"Erreur lors de la mise à jour du vendeur\");\n    }\n  };\n\n  if (!seller) return <p>Chargement...</p>;\n\n  const breadcrumbItems = [\n    { label: \"Accueil\", path: \"/\" },\n    { label: propSellerId ? \"Profil\" : \"Vendeurs\", path: propSellerId ? \"/seller\" : \"/sellers\" },\n    { label: seller.legal_name || \"Détail\", path: propSellerId ? \"/seller\" : `/sellers/${id}` },\n  ];\n\n  return (\n    <div className=\"container mt-4\">\n      <Breadcrumb items={breadcrumbItems} />\n\n      {successMessage && <div className=\"alert alert-success\">{successMessage}</div>}\n      {errorMessage && <div className=\"alert alert-danger\">{errorMessage}</div>}\n\n      <SellerForm\n        onSubmit={isEditing ? handleUpdate : undefined}\n        disabled={!isEditing}\n        initialData={seller}\n      />\n\n      <div className=\"mt-4 mb-5 d-flex justify-content-end gap-2\">\n        {isEditing ? (\n          <CancelButton onClick={() => setIsEditing(false)} />\n        ) : (\n          <EditButton onClick={() => setIsEditing(true)}>Modifier</EditButton>\n        )}\n      </div>\n    </div>\n  );\n}\n"],"mappings":"AA4DsB;AA3DtB,OAAO,SAAS,WAAW,gBAAgB;AAC3C,SAAS,iBAAiB;AAC1B,OAAO,gBAAgB;AACvB,OAAO,gBAAgB;AACvB,SAAS,YAAY,oBAAoB;AACzC,SAAS,wBAAwB;AAEjC,wBAAwB,aAAa,EAAE,UAAU,aAAa,GAAG;AAC/D,QAAM,EAAE,IAAI,QAAQ,IAAI,UAAU;AAClC,QAAM,KAAK,gBAAgB;AAC3B,UAAQ,IAAI,kCAAkC,EAAE;AAEhD,QAAM,CAAC,QAAQ,SAAS,IAAI,SAAS,IAAI;AACzC,QAAM,CAAC,WAAW,YAAY,IAAI,SAAS,KAAK;AAChD,QAAM,CAAC,gBAAgB,iBAAiB,IAAI,SAAS,EAAE;AACvD,QAAM,CAAC,cAAc,eAAe,IAAI,SAAS,EAAE;AAEnD,QAAM,EAAE,eAAe,aAAa,IAAI,iBAAiB;AAEzD,YAAU,MAAM;AACd,QAAI,CAAC,GAAI;AAET,QAAI,YAAY;AAEhB,UAAM,aAAa,YAAY;AAC7B,UAAI;AACF,cAAM,OAAO,MAAM,cAAc,EAAE;AACnC,YAAI,CAAC,KAAK,cAAe,MAAK,gBAAgB;AAC9C,YAAI,UAAW,WAAU,IAAI;AAAA,MAC/B,SAAS,KAAK;AACZ,gBAAQ,MAAM,GAAG;AACjB,YAAI,UAAW,iBAAgB,sCAAsC;AAAA,MACvE;AAAA,IACF;AAEA,eAAW;AAEX,WAAO,MAAM;AACX,kBAAY;AAAA,IACd;AAAA,EACF,GAAG,CAAC,IAAI,aAAa,CAAC;AAEtB,QAAM,eAAe,OAAO,gBAAgB;AAC1C,QAAI,CAAC,YAAY,cAAe,aAAY,gBAAgB;AAE5D,QAAI;AACF,YAAM,OAAO,MAAM,aAAa,IAAI,WAAW;AAC/C,UAAI,CAAC,KAAK,cAAe,MAAK,gBAAgB;AAC9C,gBAAU,IAAI;AACd,mBAAa,KAAK;AAClB,wBAAkB,qCAAqC;AACvD,aAAO,SAAS,EAAE,KAAK,GAAG,UAAU,SAAS,CAAC;AAC9C,iBAAW,MAAM,kBAAkB,EAAE,GAAG,GAAI;AAAA,IAC9C,SAAS,KAAK;AACZ,cAAQ,MAAM,GAAG;AACjB,sBAAgB,0CAA0C;AAAA,IAC5D;AAAA,EACF;AAEA,MAAI,CAAC,OAAQ,QAAO,uBAAC,OAAE,6BAAH;AAAA;AAAA;AAAA;AAAA,SAAgB;AAEpC,QAAM,kBAAkB;AAAA,IACtB,EAAE,OAAO,WAAW,MAAM,IAAI;AAAA,IAC9B,EAAE,OAAO,eAAe,WAAW,YAAY,MAAM,eAAe,YAAY,WAAW;AAAA,IAC3F,EAAE,OAAO,OAAO,cAAc,UAAU,MAAM,eAAe,YAAY,YAAY,EAAE,GAAG;AAAA,EAC5F;AAEA,SACE,uBAAC,SAAI,WAAU,kBACb;AAAA,2BAAC,cAAW,OAAO,mBAAnB;AAAA;AAAA;AAAA;AAAA,WAAoC;AAAA,IAEnC,kBAAkB,uBAAC,SAAI,WAAU,uBAAuB,4BAAtC;AAAA;AAAA;AAAA;AAAA,WAAqD;AAAA,IACvE,gBAAgB,uBAAC,SAAI,WAAU,sBAAsB,0BAArC;AAAA;AAAA;