:39},"4":{"loc":{"start":{"line":58,"column":4},"end":{"line":62,"column":12}},"type":"binary-expr","locations":[{"start":{"line":58,"column":4},"end":{"line":58,"column":12}},{"start":{"line":58,"column":32},"end":{"line":62,"column":12}}],"line":58},"5":{"loc":{"start":{"line":63,"column":4},"end":{"line":67,"column":12}},"type":"binary-expr","locations":[{"start":{"line":63,"column":4},"end":{"line":63,"column":9}},{"start":{"line":63,"column":29},"end":{"line":67,"column":12}}],"line":63}},"s":{"0":13,"1":13,"2":1,"3":4},"f":{"0":13,"1":1,"2":4},"b":{"0":[3,10],"1":[1,12],"2":[3,10],"3":[3,10],"4":[13,1],"5":[13,1]},"inputSourceMap":{"version":3,"sources":["/home/francois/dev/eInvoicing/frontend/src/components/form/PasswordInput.jsx"],"sourcesContent":["import { useState } from 'react';\nimport { Eye, EyeOff } from 'lucide-react';\n\nexport default function PasswordInput({ id, name, label, value, onChange, disabled, error, helpText }) {\n  const [show, setShow] = useState(false);\n\n  return (\n    <div className=\"relative w-full\">\n      <label htmlFor={id} className=\"block mb-1 font-medium text-gray-700\">{label}</label>\n      <input\n        type={show ? 'text' : 'password'}\n        id={id}\n        name={name}\n        value={value}\n        onChange={(e) => onChange(e.target.value)}\n        disabled={disabled}\n        className={`border p-2 w-full rounded-md pr-10 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-blue-400 ${\n          error ? 'border-red-500' : 'border-gray-300'\n        }`}\n      />\n      <button\n        type=\"button\"\n        onClick={() => setShow(!show)}\n        className=\"absolute right-2 top-1/2 -translate-y-1/2 bg-gray-100 hover:bg-gray-200 text-gray-600 hover:text-gray-900 rounded-full p-1 transition-all duration-200 shadow-sm\"\n        aria-label={show ? 'Masquer le mot de passe' : 'Afficher le mot de passe'}\n      >\n        {show ? <EyeOff size={18} /> : <Eye size={18} />}\n      </button>\n      {helpText && <p className=\"text-sm text-gray-500 mt-1\">{helpText}</p>}\n      {error && <p className=\"text-sm text-red-500 mt-1\">{error}</p>}\n    </div>\n  );\n}\n"],"mappings":"AAQM;AARN,SAAS,gBAAgB;AACzB,SAAS,KAAK,cAAc;AAE5B,wBAAwB,cAAc,EAAE,IAAI,MAAM,OAAO,OAAO,UAAU,UAAU,OAAO,SAAS,GAAG;AACrG,QAAM,CAAC,MAAM,OAAO,IAAI,SAAS,KAAK;AAEtC,SACE,uBAAC,SAAI,WAAU,mBACb;AAAA,2BAAC,WAAM,SAAS,IAAI,WAAU,wCAAwC,mBAAtE;AAAA;AAAA;AAAA;AAAA,WAA4E;AAAA,IAC5E;AAAA,MAAC;AAAA;AAAA,QACC,MAAM,OAAO,SAAS;AAAA,QACtB;AAAA,QACA;AAAA,QACA;AAAA,QACA,UAAU,CAAC,MAAM,SAAS,EAAE,OAAO,KAAK;AAAA,QACxC;AAAA,QACA,WAAW,gHACT,QAAQ,mBAAmB,iBAC7B;AAAA;AAAA,MATF;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,IAUA;AAAA,IACA;AAAA,MAAC;AAAA;AAAA,QACC,MAAK;AAAA,QACL,SAAS,MAAM,QAAQ,CAAC,IAAI;AAAA,QAC5B,WAAU;AAAA,QACV,cAAY,OAAO,4BAA4B;AAAA,QAE9C,iBAAO,uBAAC,UAAO,MAAM,MAAd;AAAA;AAAA;AAAA;AAAA,eAAkB,IAAK,uBAAC,OAAI,MAAM,MAAX;AAAA;AAAA;AAAA;AAAA,eAAe;AAAA;AAAA,MANhD;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,IAOA;AAAA,IACC,YAAY,uBAAC,OAAE,WAAU,8BAA8B,sBAA3C;AAAA;AAAA;AAAA;AAAA,WAAoD;AAAA,IAChE,SAAS,uBAAC,OAAE,WAAU,6BAA6B,mBAA1C;AAAA;AAAA;AAAA;AAAA,WAAgD;AAAA,OAtB5D;AAAA;AAAA;AAAA;AAAA,SAuBA;AAEJ;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"85ae0e748032ffbaf57fdfc835ebec96e7ba1df6"}}