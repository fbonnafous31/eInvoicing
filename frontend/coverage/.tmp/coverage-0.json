         </button>\n        ))}\n      </div>\n\n      {/* PDF */}\n      <div style={{ flex: 1, overflowY: \"auto\", border: \"1px solid #ccc\", borderRadius: \"4px\" }}>\n        <PdfViewer fileUrl={`${backendUrl}/uploads/invoices/${attachments[activeIndex].stored_name}`} />\n      </div>\n    </div>\n  );\n};\n\nexport default InvoiceTabs;\n"],"mappings":"AAOkD;AANlD,SAAS,gBAAgB;AACzB,OAAO,eAAe;AAEtB,MAAM,cAAc,CAAC,EAAE,aAAa,WAAW,MAAM;AACnD,QAAM,CAAC,aAAa,cAAc,IAAI,SAAS,CAAC;AAEhD,MAAI,CAAC,eAAe,CAAC,YAAY,OAAQ,QAAO,uBAAC,SAAI,oCAAL;AAAA;AAAA;AAAA;AAAA,SAAyB;AAEzE,QAAM,iBAAiB,CAAC,UAAU,eAAe,KAAK;AAEtD,SACE,uBAAC,SAAI,OAAO,EAAE,SAAS,QAAQ,eAAe,UAAU,QAAQ,OAAO,GAGrE;AAAA,2BAAC,SAAI,OAAO;AAAA,MACV,SAAS;AAAA,MACT,cAAc;AAAA,MACd,cAAc;AAAA,MACd,WAAW;AAAA,IACb,GACG,sBAAY,IAAI,CAAC,KAAK,QACrB;AAAA,MAAC;AAAA;AAAA,QAEC,SAAS,MAAM,eAAe,GAAG;AAAA,QACjC,OAAO;AAAA,UACL,SAAS;AAAA,UACT,QAAQ;AAAA,UACR,cAAc,QAAQ,cAAc,sBAAsB;AAAA,UAC1D,YAAY;AAAA,UACZ,QAAQ;AAAA,UACR,YAAY,QAAQ,cAAc,QAAQ;AAAA,UAC1C,YAAY;AAAA,QACd;AAAA,QAEC,cAAI;AAAA;AAAA,MAZA,IAAI;AAAA,MADX;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,IAcA,CACD,KAtBH;AAAA;AAAA;AAAA;AAAA,WAuBA;AAAA,IAGA,uBAAC,SAAI,OAAO,EAAE,MAAM,GAAG,WAAW,QAAQ,QAAQ,kBAAkB,cAAc,MAAM,GACtF,iCAAC,aAAU,SAAS,GAAG,UAAU,qBAAqB,YAAY,WAAW,EAAE,WAAW,MAA1F;AAAA;AAAA;AAAA;AAAA,WAA8F,KADhG;AAAA;AAAA;AAAA;AAAA,WAEA;AAAA,OA/BF;AAAA;AAAA;AAAA;AAAA,SAgCA;AAEJ;AAEA,eAAe;","names":[]},"_coverageSchema":"1a1c01bbd47fc00a2c39e90264f33305004495a9","hash":"0ef284a932095529853e54e860a5598fea7c58d5"}}