,"6":[8,8],"7":[2,6],"8":[8,7],"9":[8,2],"10":[2,1]},"inputSourceMap":{"version":3,"sources":["/home/francois/dev/eInvoicing/frontend/src/components/form/TextAreaField.jsx"],"sourcesContent":["import React from \"react\";\n\nexport default function TextAreaField({\n  id,\n  name,\n  label,\n  value,\n  onChange,\n  onBlur,\n  touched,       // ✅ vient du hook\n  required = false,\n  error,\n  submitted = false,\n  rows = 2,\n  ...props\n}) {\n  const hasError =\n    (required && touched && !value) ||\n    (required && submitted && !value) ||\n    Boolean(error);\n\n  return (\n    <div className=\"mb-3\">\n      <label htmlFor={id || name} className=\"form-label\">\n        {label} {required && \"*\"}\n      </label>\n      <textarea\n        id={id || name}\n        name={name}\n        className={`form-control ${hasError ? \"is-invalid\" : \"\"}`}\n        rows={rows}\n        value={value || \"\"}\n        onChange={(e) => onChange?.(e.target.value)}  \n        onBlur={() => onBlur?.(name)}   // appelle handleBlur(field) du hook\n        {...props}\n      />\n      {hasError && (\n        <small className=\"text-danger\">\n          {error || \"Ce champ est obligatoire\"}\n        </small>\n      )}\n    </div>\n  );\n}\n"],"mappings":"AAuBM;AAvBN,OAAO,WAAW;AAElB,wBAAwB,cAAc;AAAA,EACpC;AAAA,EACA;AAAA,EACA;AAAA,EACA;AAAA,EACA;AAAA,EACA;AAAA,EACA;AAAA;AAAA,EACA,WAAW;AAAA,EACX;AAAA,EACA,YAAY;AAAA,EACZ,OAAO;AAAA,EACP,GAAG;AACL,GAAG;AACD,QAAM,WACH,YAAY,WAAW,CAAC,SACxB,YAAY,aAAa,CAAC,SAC3B,QAAQ,KAAK;AAEf,SACE,uBAAC,SAAI,WAAU,QACb;AAAA,2BAAC,WAAM,SAAS,MAAM,MAAM,WAAU,cACnC;AAAA;AAAA,MAAM;AAAA,MAAE,YAAY;AAAA,SADvB;AAAA;AAAA;AAAA;AAAA,WAEA;AAAA,IACA;AAAA,MAAC;AAAA;AAAA,QACC,IAAI,MAAM;AAAA,QACV;AAAA,QACA,WAAW,gBAAgB,WAAW,eAAe,EAAE;AAAA,QACvD;AAAA,QACA,OAAO,SAAS;AAAA,QAChB,UAAU,CAAC,MAAM,WAAW,EAAE,OAAO,KAAK;AAAA,QAC1C,QAAQ,MAAM,SAAS,IAAI;AAAA,QAC1B,GAAG;AAAA;AAAA,MARN;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,IASA;AAAA,IACC,YACC,uBAAC,WAAM,WAAU,eACd,mBAAS,8BADZ;AAAA;AAAA;AAAA;