rMessage('');\n    setSuccessMessage('');\n\n    try {\n      // Création via le service, token géré automatiquement\n      await invoiceService.createInvoice(formData);\n\n      setSuccessMessage(\"Facture créée avec succès ! 🎉\");\n      window.scrollTo({ top: 0, behavior: \"smooth\" });\n\n      setTimeout(() => {\n        setSuccessMessage('');\n        navigate(\"/invoices\");\n      }, 2000);\n\n    } catch (error) {\n      const backendMessage = error.message || \"Erreur lors de la création de la facture\";\n      setErrorMessage(backendMessage);\n      window.scrollTo({ top: 0, behavior: \"smooth\" });\n\n    } finally {\n      setIsSubmitting(false);\n    }\n  };\n\n  const breadcrumbItems = [\n    { label: 'Accueil', path: '/' },\n    { label: 'Factures', path: '/invoices' },\n    { label: 'Nouvelle facture', path: '/invoices/new' },\n  ];\n\n  return (\n    <div className=\"container mt-4\">\n      <h1 className=\"visually-hidden\">Créer une nouvelle facture</h1>\n\n      <Breadcrumb items={breadcrumbItems} />\n\n      {successMessage && <div className=\"alert alert-success\">{successMessage}</div>}\n      {errorMessage && <div className=\"alert alert-danger\">{errorMessage}</div>}\n\n      <InvoiceForm onSubmit={handleCreateInvoice} disabled={isSubmitting} />\n    </div>\n  );\n}\n"],"mappings":"AAiDM;AAjDN,OAAO,SAAS,gBAAgB;AAChC,SAAS,mBAAmB;AAC5B,OAAO,iBAAiB;AACxB,OAAO,gBAAgB;AACvB,SAAS,yBAAyB;AAElC,wBAAwB,aAAa;AACnC,QAAM,WAAW,YAAY;AAC7B,QAAM,iBAAiB,kBAAkB;AAEzC,QAAM,CAAC,gBAAgB,iBAAiB,IAAI,SAAS,EAAE;AACvD,QAAM,CAAC,cAAc,eAAe,IAAI,SAAS,EAAE;AACnD,QAAM,CAAC,cAAc,eAAe,IAAI,SAAS,KAAK;AAEtD,QAAM,sBAAsB,OAAO,aAAa;AAC9C,oBAAgB,IAAI;AACpB,oBAAgB,EAAE;AAClB,sBAAkB,EAAE;AAEpB,QAAI;AAEF,YAAM,eAAe,cAAc,QAAQ;AAE3C,wBAAkB,gCAAgC;AAClD,aAAO,SAAS,EAAE,KAAK,GAAG,UAAU,SAAS,CAAC;AAE9C,iBAAW,MAAM;AACf,0BAAkB,EAAE;AACpB,iBAAS,WAAW;AAAA,MACtB,GAAG,GAAI;AAAA,IAET,SAAS,OAAO;AACd,YAAM,iBAAiB,MAAM,WAAW;AACxC,sBAAgB,cAAc;AAC9B,aAAO,SAAS,EAAE,KAAK,GAAG,UAAU,SAAS,CAAC;AAAA,IAEhD,U