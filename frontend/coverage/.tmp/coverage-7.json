ailModal = ({ show, onClose, onSend, defaultValues }) => {\n  const [to, setTo] = useState(defaultValues.to || '');\n  const [subject, setSubject] = useState(defaultValues.subject || '');\n  const [message, setMessage] = useState(defaultValues.message || '');\n  const [error, setError] = useState(null);\n\n  useEffect(() => {\n    setTo(defaultValues.to || '');\n    setSubject(defaultValues.subject || '');\n    setMessage(defaultValues.message || '');\n    setError(validateEmail(defaultValues.to || ''));\n  }, [defaultValues, show]);\n\n  const handleSubmit = () => {\n    const validationError = validateEmail(to);\n    if (validationError) {\n      setError(validationError);\n      return;\n    }\n\n    onSend({ to, subject, message });\n    onClose();\n  };\n\n  const emailHasError = !!error;\n\n  return (\n    <Modal show={show} onHide={onClose} centered>\n      <Modal.Header closeButton>\n        <Modal.Title>✉️ Envoyer la facture par email</Modal.Title>\n      </Modal.Header>\n\n      <Modal.Body>\n        {emailHasError && (\n          <Alert variant=\"danger\" className=\"mb-3\">\n            {error}\n          </Alert>\n        )}\n\n        <Form>\n          <Form.Group className=\"mb-3\" controlId=\"emailTo\">\n            <Form.Label>Destinataire</Form.Label>\n            <Form.Control\n              type=\"email\"\n              value={to}\n              onChange={(e) => {\n                setTo(e.target.value);\n                const validationError = validateEmail(e.target.value);\n                setError(validationError);\n              }}\n              placeholder=\"exemple@client.fr\"\n              isInvalid={emailHasError} \n            />\n            <Form.Control.Feedback type=\"invalid\">\n              {error || 'Adresse email invalide.'}\n            </Form.Control.Feedback>\n          </Form.Group>\n\n          <Form.Group className=\"mb-3\">\n            <Form.Label>Sujet</Form.Label>\n            <Form.Control\n              type=\"text\"\n              value={subject}\n              onChange={(e) => setSubject(e.target.value)}\n            />\n          </Form.Group>\n\n          <Form.Group>\n            <Form.Label>Message</Form.Label>\n            <Form.Control\n              as=\"textarea\"\n              rows={6}\n              value={message}\n              onChange={(e) => setMessage(e.target.value)}\n            />\n          </Form.Group>\n        </Form>\n      </Modal.Body>\n\n      <Modal.Footer>\n        <Button variant=\"secondary\" onClick={onClose}>\n          Annuler\n        </Button>\n        <Button\n          variant=\"primary\"\n          onClick={handleSubmit}\n          disabled={!!validateEmail(to)} \n        >\n          Envoyer\n        </Button>\n      </Modal.Footer>\n    </Modal>\n  );\n};\n\nexport default EmailModal;\n"],"mappings":"AAiCQ;AAjCR,OAAO,SAAS,UAAU,iBAAiB;AAC3C,SAAS,OAAO,QAAQ,MAAM,aAAa;AAC3C,SAAS,qBAAqB;AAE9B,MAAM,aAAa,CAAC,EAAE,MAAM,SAAS,QAAQ,cAAc,MAAM;AAC/D,QAAM,CAAC,IAAI,KAAK,IAAI,SAAS,cAAc,MAAM,EAAE;AACnD,QAAM,CAAC,SAAS,UAAU,IAAI,SAAS,cAAc,WAAW,EAAE;AAClE,QAAM,CAAC,SAAS,UAAU,IAAI,SAAS,cAAc,WAAW,EAAE;AAClE,QAAM,CAAC,OAAO,QAAQ,IAAI,SAAS,IAAI;AAEvC,YAAU,MAAM;AACd,UAAM,cAAc,MAAM,EAAE;AAC5B,eAAW,cAAc,WAAW,EAAE;AACtC,eAAW,cAAc,WAAW,EAAE;AACtC,aAAS,cAAc,cAAc,MAAM,EAAE,CAAC;AAAA,EAChD,GAAG,CAAC,eAAe,IAAI,CAAC;AAExB,QAAM,eAAe,MAAM;AACzB,UAAM,kBAAkB,cAAc,EAAE;AACxC,QAAI,iBAAiB;AACnB,eAAS,eAAe;AACxB;AAAA,IACF;AAEA,WAAO,EAAE,IAAI,SAAS,QAAQ,CAAC;AAC/B,YAAQ;AAAA,EACV;AAEA,QAAM,gBAAgB,CAAC,CAAC;AAExB,SACE,uBAAC,SAAM,MAAY,QAAQ,SAAS,UAAQ,MAC1C;AAAA,2BAAC,MAAM,QAAN,EAAa,aAAW,MACvB,iCAAC,MAAM,OAAN,EAAY,+CAAb;AAAA;AAAA;AAAA;AAAA,WAA4C,KAD9C;AAAA;AAAA;AAAA;AAAA,WAEA;AAAA,IAEA,uBAAC,MAAM,MAAN,EACE;AAAA,uBACC,uBAAC,SAAM,SAAQ,UAAS,WAAU,QAC/B,mBADH;AAAA;AAAA;AAAA;AAAA,aAEA;AAAA,MAGF,uBAAC,QACC;AAAA,+BAAC,KAAK,OAAL,EAAW,WAAU,QAAO,WAAU,WACrC;AAAA,iCAAC,KAAK,OAAL,EAAW,4BAAZ;AAAA;AAAA;AAAA;AAAA,iBAAwB;AAAA,UACxB;AAAA,YAAC,KAAK;AAAA,YAAL;AAAA,cACC,MAAK;AAAA,cACL,OAAO;AAAA,cACP,UAA