 label,\n  name,\n  value,\n  onChange,\n  onBlur,\n  touched,      // ✅ vient du hook\n  options = [],\n  required = false,\n  error,\n  submitted = false,\n  ...props\n}) {\n  const hasError =\n    (required && touched && !value) ||\n    (required && submitted && !value) ||\n    Boolean(error);\n\n  return (\n    <div className=\"mb-3\">\n      <label className=\"form-label\">\n        {label} {required && \"*\"}\n      </label>\n      <select\n        name={name}\n        className={`form-control ${hasError ? \"is-invalid\" : \"\"}`}\n        value={value || \"\"}\n        onChange={(e) => onChange?.(e.target.value)}  \n        onBlur={() => onBlur?.(name)}   // appelle handleBlur(field) du hook\n        {...props}\n      >\n        <option value=\"\">-- Sélectionner --</option>\n        {options.map((opt) => (\n          <option key={opt.value} value={opt.value}>\n            {opt.label}\n          </option>\n        ))}\n      </select>\n      {hasError && (\n        <small className=\"text-danger\">\n          {error || \"Ce champ est obligatoire\"}\n        </small>\n      )}\n    </div>\n  );\n}\n"],"mappings":"AAsBM;AAtBN,OAAO,WAAW;AAElB,wBAAwB,YAAY;AAAA,EAClC;AAAA,EACA;AAAA,EACA;AAAA,EACA;AAAA,EACA;AAAA,EACA;AAAA;AAAA,EACA,UAAU,CAAC;AAAA,EACX,WAAW;AAAA,EACX;AAAA,EACA,YAAY;AAAA,EACZ,GAAG;AACL,GAAG;AACD,QAAM,WACH,YAAY,WAAW,CAAC,SACxB,YAAY,aAAa,CAAC,SAC3B,QAAQ,KAAK;AAEf,SACE,uBAAC,SAAI,WAAU,QACb;AAAA,2BAAC,WAAM,WAAU,cACd;AAAA;AAAA,MAAM;AAAA,MAAE,YAAY;AAAA,SADvB;AAAA;AAAA;AAAA;AAAA,WAEA;AAAA,IACA;AAAA,MAAC;AAAA;AAAA,QACC;AAAA,QACA,WAAW,gBAAgB,WAAW,eAAe,EAAE;AAAA,QACvD,OAAO,SAAS;AAAA,QAChB,UAAU,CAAC,MAAM,WAAW,EAAE,OAAO,KAAK;AAAA,QAC1C,QAAQ,MAAM,SAAS,IAAI;AAAA,QAC1B,GAAG;AAAA,QAEJ;AAAA,iCAAC,YAAO,OAAM,IAAG,kCAAjB;AAAA;AAAA;AAAA;AAAA,iBAAmC;AAAA,UAClC,QAAQ,IAAI,CAAC,QACZ,uBAAC,YAAuB,OAAO,IAAI,OAChC,cAAI,SADM,IAAI,OAAjB;AAAA;AAAA;AAAA;AAAA,iBAEA,CACD;AAAA;AAAA;AAAA,MAbH;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA;AAAA,IAcA;AAAA,IACC,YACC,uBAAC,WAAM,WAAU,eACd,mBAAS,8BADZ;AA