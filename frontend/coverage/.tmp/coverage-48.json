    intervalTime,\n          20000\n        );\n\n        if (pdpStatus?.technicalStatus) {\n          onTechnicalStatusChange?.(row.id, pdpStatus.technicalStatus);\n\n          if ([\"validated\", \"rejected\"].includes(pdpStatus.technicalStatus.toLowerCase())) {\n            clearInterval(timer);\n          }\n        }\n      } catch (err) {\n        console.error(\"Erreur polling PDP:\", err);\n        clearInterval(timer);\n      }\n    }, intervalTime);\n\n    // Première vérification immédiate\n    (async () => {\n      try {\n        const pdpStatus = await invoiceService.pollInvoiceStatusPDP(\n          row.submissionId,\n          intervalTime,\n          20000\n        );\n        if (pdpStatus?.technicalStatus) {\n          onTechnicalStatusChange?.(row.id, pdpStatus.technicalStatus);\n        }\n      } catch (err) {\n        console.error(\"Erreur polling PDP initial :\", err);\n      }\n    })();\n\n    return () => {\n      isMounted = false;\n      clearInterval(timer);\n    };\n  }, [row.submissionId, statusKey, invoiceService, onTechnicalStatusChange, row.id]);\n\n  return (\n    <div style={{ textAlign: \"center\" }}>\n      <span\n        style={{\n          display: \"inline-block\",\n          padding: \"2px 6px\",\n          borderRadius: \"4px\",\n          backgroundColor: color,\n          color: \"white\",\n          fontWeight: 500,\n          fontSize: \"0.85em\",\n        }}\n      >\n        {label}\n      </span>\n    </div>\n  );\n}\n"],"mappings":"AAoEM;AApEN,OAAO,SAAS,iBAAiB;AACjC,SAAS,UAAU;AAEnB,wBAAwB,oBAAoB,EAAE,KAAK,gBAAgB,wBAAwB,GAAG;AAC5F,QAAM,SAAS,IAAI,oBAAoB;AACvC,QAAM,YAAY,OAAO,YAAY;AACrC,QAAM,QAAQ,GAAG,gBAAgB,SAAS,KAAK;AAE/C,MAAI,QAAQ;AACZ,MAAI,cAAc,WAAY,SAAQ;AAAA,WAC7B,cAAc,YAAa,SAAQ;AAAA,WACnC,cAAc,WAAY,SAAQ;AAAA,WAClC,cAAc,QAAS,SAAQ;AAExC,YAAU,MAAM;AACd,QAAI,CAAC,IAAI,aAAc;AACvB,QAAI,CAAC,aAAa,UAAU,EAAE,SAAS,SAAS,EAAG;AAEnD,QAAI,YAAY;AAChB,UAAM,eAAe;AAErB,UAAM,QAAQ,YAAY,YAAY;AACpC,UAAI,CAAC,UAAW;AAEhB,UAAI;AACF,cAAM,Y